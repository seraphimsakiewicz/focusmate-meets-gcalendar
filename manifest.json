{
  "manifest_version": 3,
  "name": "Focusmate Calendar Overlay",
  "version": "0.1.0",
  "description": "See your Google Calendar events overlaid on your Focusmate schedule",

  "permissions": [
    "identity",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://app.focusmate.com/dashboard"
  ],

  "oauth2": {
    "client_id": "320937222380-5eth13u87b8433sh319ei5gbqbmjugc5.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.focusmate.com/*", "https://app.focusmate.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
